{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; pnpm exec oxfmt \"$f\"; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Formatting..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck && pnpm lint:fix 2>/dev/null || true",
            "timeout": 120,
            "statusMessage": "Type checking and linting..."
          }
        ]
      }
    ]
  }
}
