{
  "name": "@mahito1594/cacoo-mcp",
  "version": "0.2.0",
  "description": "An unofficial MCP Server for Cacoo <https://cacoo.com>",
  "keywords": [
    "cacoo",
    "mcp",
    "model-context-protocol",
    "nulab"
  ],
  "homepage": "https://github.com/mahito1594/cacoo-mcp#readme",
  "bugs": {
    "url": "https://github.com/mahito1594/cacoo-mcp/issues"
  },
  "license": "MIT",
  "author": "Mahito Tanno",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahito1594/cacoo-mcp.git"
  },
  "bin": {
    "cacoo-mcp": "./dist/index.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "README_en.md",
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt --check",
